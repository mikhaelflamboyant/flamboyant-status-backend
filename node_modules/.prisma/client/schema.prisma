generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(uuid())
  email            String             @unique
  name             String
  project_requests ProjectRequester[]
  password         String
  role             String             @default("ANALISTA")
  status           String             @default("PENDENTE")
  area             String             @default("")
  created_at       DateTime           @default(now())
  notifications    Notification[]
  tasks_created    Task[]             @relation("TaskAuthor")
  tasks_assigned   Task[]             @relation("TaskAssignee")
  api_tokens       ApiToken[]

  projects_led      Project[]            @relation("ProjectLeader")
  project_members   ProjectMember[]
  status_updates    StatusUpdate[]
  requirements      Requirement[]
  req_history_edits RequirementHistory[]
}

model Project {
  id             String             @id @default(uuid())
  title          String
  area           String
  requester_name String             @default("")
  requesters     ProjectRequester[]
  execution_type String             @default("INTERNA")
  priority       Int                @default(3)
  description    String
  budget_planned Float?
  budget_actual  Float?
  go_live        DateTime
  costs          ProjectCost[]
  current_phase  String             @default("RECEBIDA")
  traffic_light  String             @default("VERDE")
  completion_pct Int                @default(0)
  archived       Boolean            @default(false)
  archived_at    DateTime?
  created_at     DateTime           @default(now())
  tasks          Task[]

  owner_id String?
  owner    User?   @relation("ProjectLeader", fields: [owner_id], references: [id])

  members        ProjectMember[]
  status_updates StatusUpdate[]
  requirements   Requirement[]
}

model ProjectMember {
  id          String   @id @default(uuid())
  project_id  String
  user_id     String
  assigned_at DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([project_id, user_id])
}

model ProjectRequester {
  id          String   @id @default(uuid())
  project_id  String
  user_id     String
  type        String   @default("SOLICITANTE")
  assigned_at DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([project_id, user_id, type])
}

model ProjectCost {
  id             String   @id @default(uuid())
  project_id     String
  name           String
  budget_planned Float
  budget_actual  Float?
  created_at     DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  type       String
  title      String
  body       String
  read       Boolean  @default(false)
  link       String?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model StatusUpdate {
  id          String   @id @default(uuid())
  project_id  String
  author_id   String
  description String
  highlights  String
  next_steps  String
  created_at  DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [author_id], references: [id])
  risks   Risk[]
}

model Risk {
  id               String @id @default(uuid())
  status_update_id String
  title            String
  description      String
  mitigation       String

  status_update StatusUpdate @relation(fields: [status_update_id], references: [id], onDelete: Cascade)
}

model Requirement {
  id         String   @id @default(uuid())
  project_id String
  author_id  String
  content    String
  updated_at DateTime @updatedAt
  created_at DateTime @default(now())

  project Project              @relation(fields: [project_id], references: [id], onDelete: Cascade)
  author  User                 @relation(fields: [author_id], references: [id])
  history RequirementHistory[]
}

model RequirementHistory {
  id               String   @id @default(uuid())
  requirement_id   String
  editor_id        String
  content_snapshot String
  edited_at        DateTime @default(now())

  requirement Requirement @relation(fields: [requirement_id], references: [id], onDelete: Cascade)
  editor      User        @relation(fields: [editor_id], references: [id])
}

model Task {
  id          String    @id @default(uuid())
  project_id  String
  author_id   String
  assignee_id String?
  title       String
  description String?
  phase       String?
  due_date    DateTime?
  completed   Boolean   @default(false)
  created_at  DateTime  @default(now())

  project  Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  author   User    @relation("TaskAuthor", fields: [author_id], references: [id])
  assignee User?   @relation("TaskAssignee", fields: [assignee_id], references: [id])
}

model ApiToken {
  id         String    @id @default(uuid())
  name       String
  token      String    @unique
  created_by String
  active     Boolean   @default(true)
  created_at DateTime  @default(now())
  last_used  DateTime?

  creator User @relation(fields: [created_by], references: [id])
}
